  (should (equal (lg-preview lg-right-o (lg-right nil)) (lg-just nil)))
  (should (equal (lg-preview lg-right-o (lg-left 10)) lg-nothing))
  (should (equal (lg-review lg-right-o 7) (lg-right 7)))
  (should (equal (lg-over lg-right-o (lambda (x) (+ x 1)) (lg-right 2)) (lg-right 3)))
  (should (equal (lg-over lg-right-o (lambda (x) (+ x 1)) (lg-left 2)) (lg-left 2))))

