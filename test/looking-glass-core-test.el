    (should (equal (lg-view name-optic profile) nil))
    (should (equal (lg-set age-optic nil profile) '(:name nil)))
    (should (equal (lg-set age-optic 42 profile) '(:name nil :age 42)))))

(ert-deftest lg-fold-review-and-indexed-combinators ()
  (let* ((tr lg-list)
         (itr lg-indexed-list)
         (reviewer (lg-unto (lambda (x) (list :wrapped x)))))
    (should (equal (lg-first-of tr '(4 5 6)) (lg-just 4)))
    (should (equal (lg-last-of tr '(4 5 6)) (lg-just 6)))
    (should (equal (lg-find-of tr (lambda (x) (> x 4)) '(1 3 5 7)) (lg-just 5)))
    (should (lg-none-of tr (lambda (x) (eq 1 (% x 2))) '(2 4 6)))
    (should (equal (lg-ifirst-of itr '(10 11)) (lg-just '(0 . 10))))
    (should (equal (lg-ilast-of itr '(10 11)) (lg-just '(1 . 11))))
    (should (equal (lg-ifind-of itr (lambda (i _x) (= i 1)) '(10 11 12)) (lg-just '(1 . 11))))
    (should (equal (lg-imap-of itr (lambda (i x) (+ i x)) '(10 11)) '(10 12)))
    (should (lg-iany-of itr (lambda (i x) (= (+ i x) 12)) '(10 11)))
    (should (lg-inone-of itr (lambda (_i x) (< x 0)) '(1 2 3)))
    (should (lg-iall-of itr (lambda (i x) (>= (+ i x) 1)) '(1 2 3)))
    (should (= (lg-icount-of itr '(1 2 3 4)) 4))
    (should (equal (lg-review reviewer 9) '(:wrapped 9)))
    (should (equal (lg-reviews reviewer #'car 9) :wrapped))))

