    (should (equal (lg-preview optic 42) (lg-just 42)))
    (should (equal (lg-review optic 42) 42))
    (should (equal (lg-preview optic nil) lg-nothing))
    (should-not (lg-has optic nil))))

(ert-deftest lg-bool-and-unbool-helpers ()
  (should (eq (lg-bool-value lg-true) t))
  (should (eq (lg-bool-value lg-false) nil))
  (should (eq (lg-bool t) lg-true))
  (should (eq (lg-bool nil) lg-false))
  (should (eq (lg-view lg-unbool lg-true) t))
  (should (eq (lg-view lg-unbool lg-false) nil))
  (should (eq (lg-review lg-unbool t) lg-true))
  (should (eq (lg-review lg-unbool nil) lg-false))
  (should-error (lg-bool-value 'nope))
  (should-error (lg-bool 1)))

