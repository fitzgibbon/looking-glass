         (optic (lg-compose lg-cdr lg-car)))
    (should (equal (lg-view optic nested) 2))
    (should (equal (lg-set optic 7 nested) '((1 . 7) . 3)))))

(ert-deftest lg-compose-operator-aliases ()
  (let ((nested '((1 . 2) . 3)))
